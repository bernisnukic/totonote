{
  "name": "totonote",
  "productName": "TotoNote",
  "version": "1.5.0",
  "description": "A desktop app for organizing lore and world-building notes",
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "start": "node node_modules/@electron-forge/cli/dist/electron-forge.js start",
    "package": "node node_modules/@electron-forge/cli/dist/electron-forge.js package",
    "make": "node node_modules/@electron-forge/cli/dist/electron-forge.js make",
    "postmake": "node scripts/verify-package.mjs",
    "verify:package": "node scripts/verify-package.mjs",
    "publish": "node node_modules/@electron-forge/cli/dist/electron-forge.js publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "ELECTRON_RUN_AS_NODE=1 ./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron ./node_modules/vitest/vitest.mjs run",
    "test:watch": "ELECTRON_RUN_AS_NODE=1 ./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron ./node_modules/vitest/vitest.mjs",
    "test:e2e:build": "node e2e/build-for-test.mjs",
    "test:e2e": "npm run test:e2e:build && npx playwright test",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "bernis",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.10",
    "electron": "40.4.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "typescript": "~5.6.0",
    "vite": "^5.4.21",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.0",
    "@tiptap/extension-bold": "^2.11.0",
    "@tiptap/extension-bullet-list": "^2.11.0",
    "@tiptap/extension-document": "^2.11.0",
    "@tiptap/extension-hard-break": "^2.11.0",
    "@tiptap/extension-heading": "^2.11.0",
    "@tiptap/extension-history": "^2.11.0",
    "@tiptap/extension-italic": "^2.11.0",
    "@tiptap/extension-list-item": "^2.11.0",
    "@tiptap/extension-ordered-list": "^2.11.0",
    "@tiptap/extension-paragraph": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-strike": "^2.11.0",
    "@tiptap/extension-text": "^2.11.0",
    "@tiptap/extension-underline": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  }
}
